[mysqld]
# MySQL Read Replica Configuration for Diecast Empire
# This configuration is for read replica instances

# Server ID (must be unique for each replica)
# Set this to different values for each replica: 2, 3, 4, etc.
server_id = 2

# Read-only mode (replicas should not accept writes)
read_only = 1
super_read_only = 1

# Replication Settings
relay_log = /var/log/mysql/mysql-relay-bin
relay_log_recovery = 1
relay_log_purge = 1
relay_log_space_limit = 10G

# Skip replication errors (use with caution)
# slave_skip_errors = 1062,1032

# Parallel Replication (for better performance)
slave_parallel_workers = 4
slave_parallel_type = LOGICAL_CLOCK
slave_preserve_commit_order = 1

# Connection Settings (same as primary)
max_connections = 500
max_connect_errors = 100
connect_timeout = 10
wait_timeout = 600
interactive_timeout = 600

# Thread Settings
thread_cache_size = 50
thread_stack = 256K

# Query Cache Settings (optimized for read-heavy workload)
query_cache_type = 1
query_cache_size = 128M
query_cache_limit = 4M
query_cache_min_res_unit = 2K

# Buffer Pool Settings (can be larger on read replicas)
innodb_buffer_pool_size = 1G
innodb_buffer_pool_instances = 4
innodb_log_buffer_size = 16M

# InnoDB Performance Settings
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
innodb_read_io_threads = 8
innodb_write_io_threads = 2

# Table and Index Settings
table_open_cache = 4000
table_definition_cache = 2000
open_files_limit = 8000

# Sort and Join Buffer Settings
sort_buffer_size = 2M
read_buffer_size = 2M
read_rnd_buffer_size = 4M
join_buffer_size = 2M

# Temporary Table Settings
tmp_table_size = 64M
max_heap_table_size = 64M

# MyISAM Settings
key_buffer_size = 32M
myisam_sort_buffer_size = 8M

# Slow Query Log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow-query.log
long_query_time = 2
log_queries_not_using_indexes = 1

# Character Set
character_set_server = utf8mb4
collation_server = utf8mb4_unicode_ci

# Performance Schema
performance_schema = ON
performance_schema_max_table_instances = 12500
performance_schema_max_table_handles = 4000
