APP_NAME="Diecast Empire"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=diecast_empire_db
DB_USERNAME=diecast_user
DB_PASSWORD=diecast_password

# Database Write Connection (Primary)
DB_WRITE_HOST=mysql

# Database Read Connections (Read Replicas)
DB_READ_HOST_1=mysql_replica_1
DB_READ_HOST_2=mysql_replica_2
DB_READ_HOST_3=mysql

# Database Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_PERSISTENT_CONNECTION=false

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@diecastempire.com"
MAIL_FROM_NAME="${APP_NAME}"

# Notification Settings
NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=true

# SMS Provider Configuration (Semaphore or Itexmo)
SMS_PROVIDER=semaphore
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=DiecastEmp
SEMAPHORE_API_URL=https://api.semaphore.co/api/v4/messages

# Alternative SMS Provider (Itexmo)
ITEXMO_API_CODE=
ITEXMO_PASSWORD=
ITEXMO_API_URL=https://www.itexmo.com/php_api/api.php

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Payment Gateway Configuration
PAYMENT_DEFAULT_GATEWAY=gcash
PAYMENT_MAX_AMOUNT=100000
PAYMENT_MIN_AMOUNT=1
PAYMENT_DAILY_LIMIT=500000
PAYMENT_FRAUD_DETECTION=true
PAYMENT_REQUIRE_VERIFICATION=true
PAYMENT_WEBHOOK_TIMEOUT=10
PAYMENT_VERIFY_WEBHOOK_SIGNATURE=true
PAYMENT_WEBHOOK_MAX_RETRIES=3
PAYMENT_WEBHOOK_RETRY_DELAY=60

# GCash Configuration
GCASH_ENABLED=true
GCASH_MERCHANT_ID=
GCASH_SECRET_KEY=
GCASH_API_URL=https://api.gcash.com
GCASH_WEBHOOK_SECRET=

# Maya Configuration
MAYA_ENABLED=true
MAYA_PUBLIC_KEY=
MAYA_SECRET_KEY=
MAYA_API_URL=https://pg-sandbox.paymaya.com
MAYA_WEBHOOK_SECRET=

# Bank Transfer Configuration
BANK_TRANSFER_ENABLED=true
BPI_ACCOUNT_NUMBER=
BPI_ACCOUNT_NAME="Diecast Empire"
BDO_ACCOUNT_NUMBER=
BDO_ACCOUNT_NAME="Diecast Empire"
METROBANK_ACCOUNT_NUMBER=
METROBANK_ACCOUNT_NAME="Diecast Empire"

# Application Specific Settings
LOYALTY_CREDITS_RATE=0.05
LOYALTY_TIER_BRONZE_THRESHOLD=0
LOYALTY_TIER_SILVER_THRESHOLD=10000
LOYALTY_TIER_GOLD_THRESHOLD=50000
LOYALTY_TIER_PLATINUM_THRESHOLD=100000

# Performance Settings
CACHE_TTL=3600
PRODUCT_CACHE_TTL=7200
USER_SESSION_TTL=86400

# Redis Cache Configuration
REDIS_CLIENT=predis
REDIS_CLUSTER=redis
REDIS_PREFIX=diecast_empire_
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# CDN Configuration
CDN_ENABLED=false
CDN_URL=
CDN_ASSETS_PATH=assets
CDN_IMAGES_PATH=images
CDN_IMAGE_OPTIMIZATION=true
CDN_IMAGE_QUALITY=85